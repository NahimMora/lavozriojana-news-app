# Sitio
NEXT_PUBLIC_SITE_URL=https://lavozriojana.com
NEXT_PUBLIC_MEDIA_URL=https://media.lavozriojana.com
NODE_ENV=development

# MySQL local XAMPP. Para Hostinger, reemplazar por los datos del hPanel.
DATABASE_URL="mysql://root@127.0.0.1:3306/lavozriojana_news_app"

# Seguridad API privada
PRIVATE_API_KEY="cambiar-por-una-clave-larga-y-secreta"
ANALYTICS_SALT="cambiar-por-otro-secreto-largo"
ALLOWED_API_ORIGINS="https://lavozriojana.com"

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_BASE_URL=https://media.lavozriojana.com
R2_ENDPOINT=
R2_REGION=auto
